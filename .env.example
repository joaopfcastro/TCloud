# ==============================================
# TCLOUD - CONFIGURAÇÃO
# ==============================================

# Diretório persistente de runtime (staging, cache e store gerenciado de settings)
# Em Docker local normalmente fica em /app/staging
# Em deploy Orange Pi deve apontar para /app/data/staging
# TCLOUD_RUNTIME_DIR=/app/staging

# ============= TELEGRAM =============
# Obtenha em: https://my.telegram.org
API_ID=12345678
API_HASH=abc123def456789...

# Crie bots em: https://t.me/BotFather
# Para múltiplos bots, separe por vírgula
BOT_TOKENS=1234567890:AABBccDDee...,9876543210:AAFFggHH...

# ID do canal principal (copie de @userinfobot ou @RawDataBot)
# Formato: -100XXXXXXXXXX
CHAT_ID=-1001234567890
TELEGRAM_OPAQUE_FILENAMES=true

# ============= MONGODB =============
# MongoDB Atlas (cloud): mongodb+srv://user:pass@cluster.mongodb.net/tcloud
# MongoDB Local: mongodb://localhost:27017
MONGODB_URI=mongodb://localhost:27017

# Nome do banco de dados
DB_NAME=tcloud

# ============= SERVIDOR FTP =============
FTP_HOST=0.0.0.0
FTP_PORT=2121

# Credenciais FTP
FTP_USER=tcloud
FTP_PASS=tcloud123

# Portas passivas (range para conexões de dados)
PASSIVE_PORTS=60000-60100

# ============= PERFORMANCE =============
# Número de workers simultâneos para upload 
# Para Raspberry Pi de 8GB RAM, recomenda-se: 6 a 8 workers (ou mais dependendo da sua banda larga)
MAX_WORKERS=8

# Tamanho dos chunks em MB (máx Telegram: ~2GB)
# Recomendado para alta velocidade/memória farta: 64 a 128MB
CHUNK_SIZE_MB=64

# Limite do cache em disco (em GB)
# Padrão: 10. Ajuste conforme o espaço do seu SD card/PenDrive
CACHE_MAX_GB=10

# Tentativas de retry em caso de erro
MAX_RETRIES=5

# Tempo máximo de staging em segundos (1 hora)
MAX_STAGING_AGE=3600

# ============= LOGGING =============
# Níveis: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============= ACESSO REMOTO NGROK (OPCIONAL) =============
# Cole aqui o seu Authtoken do Ngrok para ter um link de acesso externo gratuito sem precisar de domínio
# Caso não vá usar, pode deixar em branco.
NGROK_AUTHTOKEN=

# ============= AUTENTICAÇÃO (JWT) =============
# Ativar autenticação para acesso remoto/mobile
AUTH_ENABLED=false

# Credenciais de login (padrão: usa FTP_USER/FTP_PASS)
# AUTH_USERNAME=tcloud
# AUTH_PASSWORD=tcloud123

# Chave secreta JWT (defina para tokens persistentes entre restarts)
# Gere uma chave segura com: python3 -c "import secrets; print(secrets.token_hex(32))"
# JWT_SECRET=cole_a_chave_gerada_aqui

# Tempo de expiração do token em horas (padrão: 72h)
# JWT_EXPIRY_HOURS=72

# ============= SSL/TLS (HTTPS) =============
# Para acesso remoto seguro — requer certificado e chave
# SSL_CERT=/caminho/para/cert.pem
# SSL_KEY=/caminho/para/key.pem

# ============= PLAYBACK WEB (OPCIONAL) =============
# WEB_SUBTITLE_EXTRACT_TIMEOUT_SECONDS=120
# WEB_VIDEO_TRANSCODE_MODE=hls_session
# WEB_PLAYBACK_SESSION_TTL=900
# WEB_PLAYBACK_RETIRE_GRACE_SECONDS=16
# WEB_PLAYBACK_HLS_SUBTITLES_MODE=hybrid
# WEB_PLAYBACK_HLS_SUBTITLE_SEGMENT_DURATION=10
# WEB_PLAYBACK_HLS_SEGMENT_TYPE=mpegts
# RELATED_SUBTITLE_DIR_NAMES=legendas,legenda,subs,subtitles,subtitle
# MKV_UPLOAD_EXTERNALIZE_SUBTITLES_MODE=compatible

# ============= COMPARTILHAMENTO PUBLICO (OPCIONAL) =============
# PUBLIC_SHARE_ENABLED=true
# PUBLIC_SHARE_ALLOW_FILE_SHARING=true
# PUBLIC_SHARE_ALLOW_FOLDER_SHARING=true
# PUBLIC_SHARE_REQUIRE_PASSWORD_BY_DEFAULT=false
# PUBLIC_SHARE_DEFAULT_EXPIRY_HOURS=0
# PUBLIC_SHARE_MAX_EXPIRY_HOURS=0
# PUBLIC_SHARE_DEFAULT_MAX_ACCESS=0
# PUBLIC_SHARE_MAX_ACCESS_LIMIT=100000
# PUBLIC_SHARE_ALLOW_ZIP_DOWNLOAD=true
# PUBLIC_SHARE_SESSION_TTL_SECONDS=1800
# PUBLIC_SHARE_METRICS_TTL_SECONDS=60
# PUBLIC_SHARE_METRICS_CONCURRENCY=2
# PUBLIC_SHARE_SHOW_MEDIA_PREVIEW=true
# PUBLIC_SHARE_AUDIT_LOG_ENABLED=true
